# Frontend (copy to frontend/.env.local)
# Recommended: proxy through Next.js (no CORS)
NEXT_PUBLIC_API_URL=/api

# Next.js → backend proxy (default in next.config.ts is 127.0.0.1:8001)
# BACKEND_URL=http://127.0.0.1:8001

# Optional: direct backend URL from the browser (bypasses Next proxy)
# NEXT_PUBLIC_API_URL=http://localhost:8001

# Backend (copy to backend/.env) — Slice 2+
TAVILY_API_KEY=tvly-...
ANTHROPIC_API_KEY=sk-ant-...
# Optional model override (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Slice 3 uses mock Thrad ads — no key required. Optional when wiring live bid:
# THRAD_STAGING_KEY=...
# Slice 7 — Overmind tracing (optional; trace panel works locally without it)
# OVERMIND_API_KEY=ovr_...
# OVERMIND_SERVICE_NAME=adblend-publisher
# OVERMIND_ENVIRONMENT=development
