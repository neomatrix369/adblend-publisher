# Frontend (copy to frontend/.env.local)
# Recommended: proxy through Next.js (no CORS)
NEXT_PUBLIC_API_URL=/api

# Optional: direct backend URL
# NEXT_PUBLIC_API_URL=http://localhost:8001

# Backend (copy to backend/.env) — used in later slices
# TAVILY_API_KEY=tvly-...
# ANTHROPIC_API_KEY=sk-ant-...
# THRAD_STAGING_KEY=...
# OVERMIND_API_KEY=...
